{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "isolatedModules": true,

    "noUncheckedIndexedAccess": true,

    "types": ["node"],

    "ignoreDeprecations": "6.0"
  }
}